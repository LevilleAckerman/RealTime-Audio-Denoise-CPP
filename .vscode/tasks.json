{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe build active file",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/EHsc",
                "/nologo",
                "/std:c++17",
                "/utf-8",
                "/Fe:",
                "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
                "${file}",
                "/I",
                "${workspaceFolder}\\3rdparty\\onnxruntime-win-x64-1.25.1\\include",
                "/I",
                "${workspaceFolder}\\include",
                "/link",
                "/LIBPATH:${workspaceFolder}\\3rdparty\\onnxruntime-win-x64-1.25.1\\lib",
                "onnxruntime.lib"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Generated task"
        }
    ]
}